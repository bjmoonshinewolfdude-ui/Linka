{
  "name": "linka",
  "version": "1.0.0",
  "description": "Marathon-inspired chat application",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "concurrently \"npm run server\" \"npm run client\"",
    "build": "cd frontend && npm install && npm run build",
    "install-client": "npm install --prefix frontend",
    "install-all": "npm install && npm run install-client",
    "heroku-postbuild": "npm run install-client && npm run build",
    "railway-build": "npm install && cd frontend && npm install && npm run build && cd .. && node server.js"
  },
  "dependencies": {
    "@chakra-ui/react": "2.10",
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.1",
    "bcryptjs": "^3.0.3",
    "colors": "^1.4.0",
    "dotenv": "^17.3.1",
    "express": "^5.2.1",
    "express-async-handler": "^1.2.0",
    "framer-motion": "^12.36.0",
    "jsonwebtoken": "^9.0.3",
    "mongoose": "^9.3.1",
    "next-themes": "^0.4.6",
    "nodemon": "^3.1.14",
    "react-icons": "^5.6.0",
    "react-router-dom": "^5.3.4",
    "socket.io": "^4.8.3",
    "concurrently": "^8.2.2"
  },
  "engines": {
    "node": "16.x"
  }
}
